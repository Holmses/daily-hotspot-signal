[runtime]
daily_run_time = "09:10"
timezone = "Asia/Shanghai"
verify_ssl = false

[paths]
raw_data_dir = "data/raw"
processed_data_dir = "data/processed"
reports_dir = "reports/generated"
logs_dir = "logs"

[strategy]
top_n = 10
history_days = 14
min_score = 45.0
fresh_hours = 36
max_items_per_source = 30
title_similarity_threshold = 0.62

authority_keywords = [
  "国务院",
  "发改委",
  "工信部",
  "财政部",
  "央行",
  "证监会",
  "交易所",
  "最高法",
  "海关总署",
  "Reuters",
  "AP",
  "SEC",
  "Federal Reserve",
]

impact_keywords = [
  "突发",
  "首次",
  "最新",
  "紧急",
  "调查",
  "处罚",
  "监管",
  "禁令",
  "法案",
  "裁员",
  "破产",
  "泄露",
  "制裁",
  "关税",
  "召回",
  "通报",
  "新规",
  "影响",
]

risk_keywords = [
  "网传",
  "爆料",
  "疑似",
  "未证实",
  "内幕",
  "小道消息",
  "传闻",
  "独家猛料",
]

low_competition_clues = [
  "公告",
  "征求意见",
  "裁判文书",
  "处罚决定",
  "招标",
  "备案",
  "财报",
  "监管函",
  "SEC filing",
  "consultation",
]

hook_keywords = [
  "千万不要",
  "不要再",
  "别再",
  "一定要",
  "注意",
  "提醒",
  "避坑",
  "禁忌",
  "不能吃",
  "别吃",
  "少吃",
  "慎用",
  "后悔",
  "很多人不知道",
  "冲上热搜",
]

audience_keywords = [
  "高考",
  "中考",
  "考生",
  "家长",
  "学生",
  "老人",
  "儿童",
  "孕妇",
  "上班族",
  "打工人",
  "司机",
  "宝妈",
]

seasonal_keywords = [
  "高考",
  "中考",
  "毕业",
  "暑假",
  "开学",
  "高温",
  "暴雨",
  "台风",
  "端午",
  "春节",
  "五一",
  "国庆",
]

life_advice_keywords = [
  "吃",
  "喝",
  "睡",
  "穿",
  "买",
  "用",
  "体检",
  "过敏",
  "中毒",
  "犯困",
  "血糖",
  "肠胃",
  "发烧",
  "空调",
  "防晒",
  "榴莲",
]

[[sources]]
name = "中国政府网要闻"
url = "https://www.gov.cn/yaowen/liebiao/YAOWENLIEBIAO.json"
kind = "json"
category = "official"
reliability = 0.95
enabled = true
max_items = 35
title_fields = ["TITLE"]
url_fields = ["URL"]
summary_fields = ["SUB_TITLE"]
published_fields = ["DOCRELPUBTIME"]

[[sources]]
name = "百度热搜"
url = "https://top.baidu.com/api/board?platform=pc&tab=realtime"
kind = "json"
category = "trend"
reliability = 0.65
enabled = true
max_items = 50
items_path = "data.cards[].content[]"
title_fields = ["word", "query"]
url_fields = ["rawUrl", "url"]
summary_fields = ["desc"]
heat_fields = ["hotScore"]

[[sources]]
name = "RSSHub 知乎热榜"
url = "https://rsshub.app/zhihu/hotlist"
kind = "rss"
category = "trend"
reliability = 0.60
enabled = false

[[sources]]
name = "Hacker News Front Page"
url = "https://news.ycombinator.com/"
kind = "html"
category = "technology"
reliability = 0.55
enabled = false
max_items = 20
html_title_selector = "span.titleline > a"

[[sources]]
name = "示例 JSON 热榜"
url = "https://example.com/hot.json"
kind = "json"
category = "trend"
reliability = 0.50
enabled = false
items_path = "data.items"
title_fields = ["title", "name"]
url_fields = ["url", "link"]
published_fields = ["published_at", "time"]
